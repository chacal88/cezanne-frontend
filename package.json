{
  "name": "recruit-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "smoke:r0": "npm run smoke:r0:http && npm run smoke:r0:ui",
    "smoke:r0:ui": "env -u NO_COLOR playwright test -c playwright.r0.config.ts",
    "smoke:r0:http": "sh ./scripts/r0-smoke-http.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.95.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.14.1",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "playwright": "^1.54.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
